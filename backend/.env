# ---------------------------------------------------------
# PHOTOMEMORY PRO - INFRASTRUCTURE CONFIGURATION
# ---------------------------------------------------------

# 1. SERVER SETTINGS
# Port must match the EXPOSE command in your Dockerfile.
PORT=5000
# Generate a random 64-character string for production security.
JWT_SECRET=your_super_secure_jwt_secret_key

# 2. DATABASE CONFIGURATION
# IMPORTANT: In Docker, we use the service name 'db' as the hostname, 
# NOT 'localhost'. This matches your docker-compose.yml services.
DATABASE_URL=postgresql://admin:password123@db:5432/photomemory

# 3. AWS CLOUD PERMISSIONS (IAM)
# These credentials must have: AmazonS3FullAccess & AmazonRekognitionFullAccess.
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
S3_BUCKET=photomemory-pro-storage

# 4. AI COLLECTIONS
# You MUST create these via AWS CLI before running the app:
# aws rekognition create-collection --collection-id users_master
REKOGNITION_USERS_COLLECTION=users_master
REKOGNITION_EVENTS_COLLECTION=event_content

# 5. MONETIZATION (STRIPE)
# Used for the 'Unlock Moment' logic in the Gallery.
STRIPE_SECRET_KEY=sk_test_...
